generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ──────────────────────────────────────────────
// User
// ──────────────────────────────────────────────
model User {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabaseUserId  String?  @unique
  email           String   @unique
  passwordHash    String?
  name            String
  role            String   @default("USER")
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Player profile
  phoneNumber     String?
  profilePhotoUrl String?
  socialAccounts  Json? // {facebook?, instagram?, whatsapp?, tiktok?}
  isVerified      Boolean  @default(false)
  verificationMethod String? // EMAIL, PHONE, ADMIN
  verificationStatus String? @default("PENDING") // PENDING, APPROVED, REJECTED

  // Player identity
  playerQrCode    String?  @unique
  teamId          String?  @db.Uuid
  soloMode        Boolean  @default(true)

  // Game participation / stats se consulta por sesiones relacionadas al equipo/ciudad/ruta

  // Safety / medical
  allergiesNotes  String?  @db.Text
  sensitivityNotes String? @db.Text

  teamMembers TeamMember[]
  payments    Payment[]

  @@map("User")
}

// ──────────────────────────────────────────────
// City
// ──────────────────────────────────────────────
model City {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  country   String
  state     String?  @default("ACTIVE")
  latitude  Float?
  longitude Float?
  imageUrl  String?
  config    Json?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  games        Game[]
  routes      Route[]
  gameSessions GameSession[]

  @@map("City")
}

// ──────────────────────────────────────────────
// Game (Template configurable — NUEVO)
// ──────────────────────────────────────────────
model Game {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId          String   @db.Uuid
  name            String
  description     String?
  durationMinutes Int      @default(120)
  difficulty      String   @default("MEDIUM")
  status          String   @default("DRAFT")
  maxPlayers      Int      @default(5)
  imageUrl        String?
  teamQrCodeHash  String?  @unique
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  city    City    @relation(fields: [cityId], references: [id], onDelete: Cascade)
  stories Story[]

  @@index([cityId])
  @@map("Game")
}

// ──────────────────────────────────────────────
// Story (Contenedor narrativo — NUEVO)
// ──────────────────────────────────────────────
model Story {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gameId       String   @db.Uuid
  name         String
  introduction String?  @db.Text
  lore         String?  @db.Text
  objectives   Json?
  rules        String?  @db.Text
  status       String   @default("DRAFT")
  difficulty   String   @default("MEDIUM")
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  game    Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  routes  Route[]
  endings StoryEnding[]

  @@index([gameId])
  @@map("Story")
}

// ──────────────────────────────────────────────
// Route (Mejorado con storyId + branching)
// ──────────────────────────────────────────────
model Route {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storyId          String   @db.Uuid
  cityId           String   @db.Uuid
  name             String
  description      String
  difficulty       String   @default("EASY")
  distanceMeters   Int
  estimatedMinutes Int
  isDefault        Boolean  @default(false)
  conditions       Json?
  status           String   @default("DRAFT")
  createdAt        DateTime @default(now()) @db.Timestamptz(6)

  story           Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  city            City            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  missions        Mission[]
  checkpoints     Checkpoint[]
  qrCodes         QRCode[]
  teams           Team[]
  gameSessions    GameSession[]
  rankings        Ranking[]

  @@index([storyId])
  @@index([cityId])
  @@map("Route")
}

// ──────────────────────────────────────────────
// Mission (Unidad jugable completa — MEJORADA)
// ──────────────────────────────────────────────
model Mission {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeId       String   @db.Uuid
  title         String
  narrative     String?  @db.Text
  description   String?  @db.Text
  orderIndex    Int
  difficulty    Int      @default(5)
  timeLimit     Int?
  status        String   @default("ACTIVE")
  checkpointId  String?  @db.Uuid
  mediaUrl      String?
  isLastMission Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  route       Route       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  checkpoint  Checkpoint? @relation(fields: [checkpointId], references: [id], onDelete: SetNull)
  challenges  Challenge[]

  @@index([routeId])
  @@map("Mission")
}

// ──────────────────────────────────────────────
// Checkpoint (Geolocalización — EXISTENTE)
// ──────────────────────────────────────────────
model Checkpoint {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeId     String   @db.Uuid
  name        String
  description String
  latitude    Float
  longitude   Float
  orderIndex  Int

  route           Route           @relation(fields: [routeId], references: [id], onDelete: Cascade)
  missions        Mission[]
  qrCodes         QRCode[]
  gameSessions    GameSession[]   @relation("CurrentCheckpoint")

  @@index([routeId])
  @@map("Checkpoint")
}

// ──────────────────────────────────────────────
// QRCode (EXISTENTE)
// ──────────────────────────────────────────────
model QRCode {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeId       String   @db.Uuid
  checkpointId  String   @db.Uuid
  code          String   @unique
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  route       Route      @relation(fields: [routeId], references: [id], onDelete: Cascade)
  checkpoint  Checkpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([checkpointId])
  @@map("QRCode")
}

// ──────────────────────────────────────────────
// Challenge (Reto/Enigma — NUEVO)
// ──────────────────────────────────────────────
model Challenge {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  missionId   String   @db.Uuid
  type        String
  prompt      String   @db.Text
  hint1       String?  @db.Text
  hint2       String?  @db.Text
  hint3       String?  @db.Text
  hint4       String?  @db.Text
  orderIndex  Int      @default(0)
  penalty     Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  mission    Mission            @relation(fields: [missionId], references: [id], onDelete: Cascade)
  answers    ChallengeAnswer[]
  unlockKeys UnlockKey[]

  @@index([missionId])
  @@map("Challenge")
}

// ──────────────────────────────────────────────
// ChallengeAnswer (Respuestas válidas — NUEVO)
// ──────────────────────────────────────────────
model ChallengeAnswer {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challengeId String   @db.Uuid
  value       String   @db.Text
  label       String?
  isCorrect   Boolean  @default(true)
  penalty     Int      @default(0)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
  @@map("ChallengeAnswer")
}

// ──────────────────────────────────────────────
// UnlockKey (Motor de desbloqueo — NUEVO)
// ──────────────────────────────────────────────
model UnlockKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challengeId String    @db.Uuid
  type        String
  keyValue    String    @unique
  expiresAt   DateTime?
  usedAt      DateTime?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
  @@map("UnlockKey")
}

// ──────────────────────────────────────────────
// StoryEnding (Finales alternativos — NUEVO)
// ──────────────────────────────────────────────
model StoryEnding {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storyId     String   @db.Uuid
  name        String
  description String   @db.Text
  conditions  Json
  narrative   String?  @db.Text
  mediaUrl    String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("StoryEnding")
}

// ──────────────────────────────────────────────
// Team
// ──────────────────────────────────────────────
model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeId   String   @db.Uuid
  name      String
  captainId String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  route           Route           @relation(fields: [routeId], references: [id], onDelete: Cascade)
  members         TeamMember[]
  gameSessions    GameSession[]
  rankings        Ranking[]

  qrCodeHash      String? @unique
  avatarUrl       String?
  gamesPlayed     Int @default(0)
  pendingStories  Int @default(0)
  globalScore     Int @default(0)

  @@index([routeId])
  @@map("Team")
}

// ──────────────────────────────────────────────
// TeamMember
// ──────────────────────────────────────────────
model TeamMember {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId   String   @db.Uuid
  userId   String   @db.Uuid
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now()) @db.Timestamptz(6)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("TeamMember")
}

// ──────────────────────────────────────────────
// GameSession
// ──────────────────────────────────────────────
model GameSession {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId              String    @db.Uuid
  routeId             String    @db.Uuid
  cityId              String    @db.Uuid
  storyId             String?   @db.Uuid
  status              String    @default("ACTIVE")
  startedAt           DateTime  @default(now()) @db.Timestamptz(6)
  finishedAt          DateTime? @db.Timestamptz(6)
  currentCheckpointId String?   @db.Uuid
  currentMissionId    String?   @db.Uuid
  score               Int       @default(0)
  hintsUsed           Int       @default(0)
  errors              Int       @default(0)
  metadata            Json?

  team              Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  route             Route       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  city              City        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  currentCheckpoint Checkpoint? @relation("CurrentCheckpoint", fields: [currentCheckpointId], references: [id], onDelete: SetNull)
  events            SessionEvent[]

  @@index([teamId])
  @@index([routeId])
  @@index([cityId])
  @@map("GameSession")
}

// ──────────────────────────────────────────────
// SessionEvent
// ──────────────────────────────────────────────
model SessionEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String   @db.Uuid
  eventType  String
  eventData  Json
  occurredAt DateTime @default(now()) @db.Timestamptz(6)

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("SessionEvent")
}

// ──────────────────────────────────────────────
// Payment (Mercado Pago)
// ──────────────────────────────────────────────
model Payment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?   @db.Uuid
  email           String
  description     String
  amount          Int
  currency        String    @default("COP")
  status          String    @default("PENDING")
  mpPaymentId     Int?      @unique
  mpPreferenceId  String?
  mpMerchantOrder Int?
  paymentMethod   String?
  metadata        Json?
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("Payment")
}

// ──────────────────────────────────────────────
// Ranking
// ──────────────────────────────────────────────
model Ranking {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeId     String   @db.Uuid
  teamId      String   @db.Uuid
  score       Int
  position    Int
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([teamId])
  @@map("Ranking")
}
